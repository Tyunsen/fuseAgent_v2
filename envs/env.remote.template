# fuseAgent remote deployment defaults
COMPOSE_PROJECT_NAME=fuseagent

# MetaDB
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Database connection pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=60
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=True

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USER=default
REDIS_PASSWORD=password

# Vector DB
VECTOR_DB_TYPE=qdrant
VECTOR_DB_CONTEXT={"url":"http://127.0.0.1","port":6333,"distance":"Cosine","timeout":1000}

# Elasticsearch
ES_HOST_NAME=127.0.0.1
ES_PORT=9200
ES_USER=
ES_PASSWORD=
ES_PROTOCOL=http

# Neo4J
NEO4J_HOST=127.0.0.1
NEO4J_PORT=7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Auth
AUTH_TYPE=cookie
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTHING_DOMAIN=
AUTHING_APP_ID=
LOGTO_DOMAIN=
LOGTO_APP_ID=
JWT_SECRET=change-me-before-production
REGISTER_MODE=unlimited

# Logging
DJANGO_LOG_LEVEL=INFO

# Celery
CELERY_FLOWER_USER=admin
CELERY_FLOWER_PASSWORD=admin
CELERY_WORKER_CONCURRENCY=4
CELERY_GRAPH_WORKER_CONCURRENCY=4
CELERY_WORKER_POOL=threads

# Object store
OBJECT_STORE_TYPE=local
OBJECT_STORE_LOCAL_ROOT_DIR=.objects
OBJECT_STORE_S3_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORE_S3_REGION=
OBJECT_STORE_S3_ACCESS_KEY=minioadmin
OBJECT_STORE_S3_SECRET_KEY=minioadmin
OBJECT_STORE_S3_BUCKET=aperag
OBJECT_STORE_S3_USE_PATH_STYLE=True

# Doc parsing
WITH_NEO4J=1
WITH_DOCRAY_GPU=0
WITH_DOCRAY=0
DOCRAY_HOST=
FUSEAGENT_GPU_DEVICE=

DEBUG=False

MAX_BOT_COUNT=10
MAX_COLLECTION_COUNT=50
MAX_DOCUMENT_COUNT=1000
MAX_CONVERSATION_COUNT=100

EMBEDDING_MAX_CHUNKS_IN_BATCH=10
CHUNK_SIZE=400
CHUNK_OVERLAP_SIZE=20

TIKTOKEN_CACHE_DIR=.cache/tiktoken
DEFAULT_ENCODING_MODEL=cl100k_base
TOKENIZERS_PARALLELISM=false

# LightRAG
GRAPH_INDEX_KV_STORAGE=PGOpsSyncKVStorage
GRAPH_INDEX_VECTOR_STORAGE=PGOpsSyncVectorStorage
GRAPH_INDEX_GRAPH_STORAGE=PGOpsSyncGraphStorage

CACHE_ENABLED=True
CACHE_TTL=86400

# Keyword extraction defaults
LLM_KEYWORD_EXTRACTION_PROVIDER=minimax
LLM_KEYWORD_EXTRACTION_MODEL=MiniMax-M2.7

# Tracing
OTEL_ENABLED=False
OTEL_SERVICE_NAME=fuseagent
OTEL_SERVICE_VERSION=1.0.0
OTEL_CONSOLE_ENABLED=False
OTEL_FASTAPI_ENABLED=True
OTEL_SQLALCHEMY_ENABLED=True
OTEL_MCP_ENABLED=True
JAEGER_ENABLED=False
JAEGER_ENDPOINT=http://localhost:14268/api/traces

MAX_CONCURRENT_EVALUATIONS=5
MAX_CONCURRENT_PROCESSING_TASKS_PER_EVALUATION=5
EVALUATION_ITEM_PROCESSING_TASK_TIMEOUT_MINUTES=15

# Host port overrides
APERAG_WEB_HOST_PORT=36130
APERAG_API_HOST_PORT=36180
APERAG_FLOWER_HOST_PORT=36555
APERAG_POSTGRES_HOST_PORT=35432
APERAG_REDIS_HOST_PORT=36379
APERAG_QDRANT_HOST_PORT=36333
APERAG_ES_HOST_PORT=39200
APERAG_NEO4J_HTTP_HOST_PORT=62139
APERAG_NEO4J_BOLT_HOST_PORT=62140

# Optional provider bootstrap after deployment
# Legacy single-provider variables are still supported by the deploy script,
# but completion + embedding can now target different providers.
BOOTSTRAP_COMPLETION_PROVIDER_NAME=minimax
BOOTSTRAP_COMPLETION_PROVIDER_BASE_URL=https://api.minimaxi.com/v1
BOOTSTRAP_COMPLETION_PROVIDER_API_KEY=
BOOTSTRAP_COMPLETION_MODEL=MiniMax-M2.7
BOOTSTRAP_COMPLETION_CUSTOM_PROVIDER=openai

BOOTSTRAP_EMBEDDING_PROVIDER_NAME=ollama
BOOTSTRAP_EMBEDDING_PROVIDER_BASE_URL=http://aperag-ollama:11434
BOOTSTRAP_EMBEDDING_PROVIDER_API_KEY=ollama
BOOTSTRAP_EMBEDDING_MODEL=bge-m3:latest
BOOTSTRAP_EMBEDDING_CUSTOM_PROVIDER=ollama
